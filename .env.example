# ---------------------------------------------------------------------------
# Trivyy environment variables. Copy to .env and fill in real values.
# Never commit a real .env (see .gitignore). REPO-5 / SEC-1.
# ---------------------------------------------------------------------------

# Runtime mode: development | test | production
NODE_ENV=development

# Port the Express API listens on
PORT=3000

# Postgres connection string (the single store — DB-1)
DATABASE_URL=postgres://trivyy:trivyy@localhost:5432/trivyy

# Secret used to sign the session cookie (minimum 16 chars).
# Generate a long random value, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-a-long-random-string

# argon2 hash of the single admin's password (SEC-1, never store the plaintext).
# Generate with: npm run hash-admin -- 'your-admin-password'
ADMIN_PASSWORD_HASH=

# Browser origin allowed by CORS. Dev: the Vite dev server. Prod: the public
# domain (the prod compose builds this from APP_DOMAIN as https://$APP_DOMAIN).
CLIENT_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# PRODUCTION DEPLOY (Phase 6) — read by docker-compose.prod.yml on the Pi.
# Copy this file to .env on the Pi and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# Public domain served through the Cloudflare Tunnel (no scheme).
APP_DOMAIN=trivyy.com

# Postgres credentials for the prod stack (the db service + DATABASE_URL).
# Use a strong password; it is not exposed publicly (no published port).
POSTGRES_USER=trivyy
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
POSTGRES_DB=trivyy

# Cloudflare Tunnel connector token for the named tunnel (Zero Trust dashboard ->
# Networks -> Tunnels -> your tunnel -> install token). It carries the tunnel's
# credentials, so treat it as a secret (SEC-1). Used only by the cloudflared
# service in docker-compose.prod.yml.
TUNNEL_TOKEN=

# ---------------------------------------------------------------------------
# CI ONLY — not read by the app at runtime. Used by .github/workflows/pr-review.yml
# Set this as a GitHub Actions repository secret, never as a committed value.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
